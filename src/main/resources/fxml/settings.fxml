<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.chatbot.controller.SettingsDialogController"
            styleClass="settings-root" prefWidth="680" prefHeight="520">

    <!-- LEFT: Category list -->
    <left>
        <ListView fx:id="categoryList" styleClass="settings-category-list" prefWidth="170" />
    </left>

    <!-- CENTER: Settings pages -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="settings-scroll">
            <StackPane fx:id="pageContainer" styleClass="settings-page-container">
                <padding>
                    <Insets top="18" right="22" bottom="18" left="22" />
                </padding>
            </StackPane>
        </ScrollPane>
    </center>

    <!-- BOTTOM: Save / Cancel -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="settings-button-bar">
            <padding>
                <Insets top="10" right="18" bottom="14" left="18" />
            </padding>
            <Button fx:id="cancelButton" text="Cancel" styleClass="settings-cancel-button" focusTraversable="false" />
            <Button fx:id="saveButton" text="Save" styleClass="settings-save-button" focusTraversable="false" />
        </HBox>
    </bottom>
</BorderPane>

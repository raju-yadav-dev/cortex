    "command": "node {file}",
    "detectCommands": ["node"],
    "needsCompilation": false,
    "timeout": 10
  },
  "java": {
    "displayName": "Java",
    "extensions": [".java"],
    "aliases": ["java"],
    "compileCommand": "javac {file}",

{
  "python": {
    "displayName": "Python",
    "extensions": [".py"],
    "aliases": ["py", "python3"],
    "command": "python {file}",
    "detectCommands": ["python", "py", "python3"],
    "needsCompilation": false,
    "timeout": 10
  },
  "javascript": {
    "displayName": "JavaScript",
    "extensions": [".js", ".mjs"],
    "aliases": ["js", "node", "nodejs"],
    "command": "node {file}",
    "detectCommands": ["node"],
    "needsCompilation": false,
    "timeout": 10
  },
  "java": {
    "displayName": "Java",
    "extensions": [".java"],
    "aliases": ["java"],
    "compileCommand": "javac {file}",
    "command": "java -cp {dir} {className}",
    "detectCommands": ["javac", "java"],
    "needsCompilation": true,
    "timeout": 10
  },
  "c": {
    "displayName": "C",
    "extensions": [".c"],
    "aliases": ["c", "c89", "c90", "c99", "c11", "c17", "c18"],
    "compileCommand": "gcc {file} -o {output}",
    "command": "{output}",
    "detectCommands": ["gcc", "clang", "cc", "tcc"],
    "needsCompilation": true,
    "timeout": 10
  },
  "cpp": {
    "displayName": "C++",
    "extensions": [".cpp", ".cc", ".cxx"],
    "aliases": ["cpp", "c++", "cc", "cxx", "c++11", "c++14", "c++17", "c++20", "c++23"],
    "compileCommand": "g++ {file} -o {output}",
    "command": "{output}",
    "detectCommands": ["g++", "clang++", "c++"],
    "needsCompilation": true,
    "timeout": 10
  },
  "powershell": {
    "displayName": "PowerShell",
    "extensions": [".ps1"],
    "aliases": ["ps", "ps1", "pwsh"],
    "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File {file}",
    "detectCommands": ["pwsh", "powershell"],
    "needsCompilation": false,
    "timeout": 10
  },
  "bash": {
    "displayName": "Bash",
    "extensions": [".sh"],
    "aliases": ["shell", "sh", "zsh"],
    "command": "bash {file}",
    "detectCommands": ["bash", "sh"],
    "needsCompilation": false,
    "timeout": 10
  }
}

{
  "python": {
    "displayName": "Python",
    "extensions": [".py"],
    "aliases": ["py", "python3"],
    "command": "python {file}",
    "detectCommands": ["python", "py", "python3"],
    "needsCompilation": false,
    "timeout": 10
  },
  "javascript": {
    "displayName": "JavaScript",
